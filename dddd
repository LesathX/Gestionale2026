<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gestione Strumentazione Laboratorio</title>
  <link rel="icon" href="data:,">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script src="https://www.gstatic.com/firebasejs/11.6.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/11.6.0/firebase-firestore-compat.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',system-ui,sans-serif;background:#f1f5f9;color:#1e293b;min-height:100vh;line-height:1.5}
    .login-screen{position:fixed;inset:0;background:linear-gradient(135deg,#0f172a 0%,#1e293b 50%,#0f172a 100%);display:flex;align-items:center;justify-content:center;z-index:1000}
    .login-screen.hidden{display:none}
    .login-box{background:#fff;border-radius:1rem;padding:2.5rem;width:100%;max-width:400px;box-shadow:0 25px 50px -12px rgba(0,0,0,.4)}
    .login-logo{text-align:center;margin-bottom:2rem}
    .login-logo i{font-size:2.5rem;color:#059669;margin-bottom:.75rem}
    .login-logo h1{font-size:1.35rem;font-weight:700;color:#0f172a}
    .login-logo p{font-size:.85rem;color:#64748b;margin-top:.25rem}
    .login-error{background:#fef2f2;color:#b91c1c;padding:.75rem;border-radius:.5rem;font-size:.875rem;margin-bottom:1rem;display:none}
    .login-error.show{display:block}
    .form-group{margin-bottom:1.1rem}
    .form-group label{display:block;font-size:.8rem;font-weight:500;color:#475569;margin-bottom:.3rem}
    .form-group input,.form-group select{width:100%;padding:.7rem .9rem;border:1px solid #e2e8f0;border-radius:.5rem;font-size:.95rem;outline:none}
    .form-group input:focus,.form-group select:focus{border-color:#10b981;box-shadow:0 0 0 3px rgba(16,185,129,.15)}
    .btn-login{width:100%;padding:.8rem;background:#059669;color:#fff;border:none;border-radius:.5rem;font-size:1rem;font-weight:600;cursor:pointer;margin-top:.5rem}
    .btn-login:hover{background:#047857}
    .login-hint{text-align:center;font-size:.75rem;color:#94a3b8;margin-top:1.25rem}
    .app{display:none}.app.show{display:block}
    .header{background:linear-gradient(to right,#1e293b,#0f172a);color:#fff}
    .header-inner{max-width:1500px;margin:0 auto;padding:1rem 1.5rem;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:.75rem}
    .logo{display:flex;align-items:center;gap:.75rem}
    .logo-icon{background:rgba(16,185,129,.2);padding:.6rem;border-radius:.75rem}
    .logo-icon i{color:#34d399;font-size:1.25rem}
    .logo h1{font-size:1.25rem;font-weight:700}.logo p{font-size:.75rem;color:#94a3b8}
    .header-actions{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center}
    .user-badge{background:rgba(255,255,255,.1);padding:.4rem .8rem;border-radius:.5rem;font-size:.8rem;display:flex;align-items:center;gap:.4rem}
    .user-badge .role{font-size:.7rem;opacity:.8}
    .btn{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem .9rem;border-radius:.5rem;font-size:.875rem;font-weight:500;border:none;cursor:pointer;color:#fff}
    .btn-secondary{background:#334155}.btn-secondary:hover{background:#475569}
    .btn-primary{background:#059669}.btn-primary:hover{background:#10b981}
    .btn-danger{background:#dc2626}.btn-danger:hover{background:#b91c1c}
    .btn-excel{background:#15803d}.btn-excel:hover{background:#166534}
    .btn-email{background:#7c3aed}.btn-email:hover{background:#6d28d9}
    .sync-badge{background:rgba(16,185,129,.2);color:#34d399;padding:.25rem .6rem;border-radius:.4rem;font-size:.7rem;margin-left:.4rem}
    .expiry-alert{display:none;background:#fff7ed;border-bottom:1px solid #fdba74;color:#9a3412;font-size:.875rem}
    .expiry-alert.show{display:block}
    .expiry-alert.danger{background:#fef2f2;border-bottom-color:#fca5a5;color:#991b1b}
    .expiry-alert-inner{max-width:1500px;margin:0 auto;padding:.75rem 1.5rem;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap}
    .expiry-alert .btn-sm{background:#c2410c;color:#fff;border:none;padding:.35rem .75rem;border-radius:.4rem;font-size:.8rem;cursor:pointer}
    .expiry-alert.danger .btn-sm{background:#b91c1c}
    .main{max-width:1500px;margin:0 auto;padding:1.5rem}
    .stats{display:grid;grid-template-columns:repeat(2,1fr);gap:.75rem;margin-bottom:1.5rem}
    @media(min-width:768px){.stats{grid-template-columns:repeat(6,1fr)}}
    .stat-card{background:#fff;border:1px solid #e2e8f0;border-radius:.75rem;padding:1rem}
    .stat-value{font-size:1.5rem;font-weight:700}.stat-label{font-size:.75rem;color:#64748b;margin-top:2px}
    .stat-green{color:#059669}.stat-amber{color:#d97706}.stat-rose{color:#e11d48}.stat-orange{color:#ea580c}.stat-red{color:#dc2626}
    .filters{background:#fff;border:1px solid #e2e8f0;border-radius:.75rem;padding:1rem;margin-bottom:1.5rem}
    .filters-inner{display:flex;flex-direction:column;gap:.75rem}
    @media(min-width:768px){.filters-inner{flex-direction:row}}
    .search-wrap{position:relative;flex:1}
    .search-wrap i{position:absolute;left:.75rem;top:50%;transform:translateY(-50%);color:#94a3b8}
    .search-wrap input{width:100%;padding:.6rem 1rem .6rem 2.4rem;border:1px solid #e2e8f0;border-radius:.5rem;font-size:.875rem;outline:none}
    .search-wrap input:focus{border-color:#10b981;box-shadow:0 0 0 3px rgba(16,185,129,.15)}
    select{padding:.6rem .75rem;border:1px solid #e2e8f0;border-radius:.5rem;font-size:.875rem;background:#fff;outline:none;min-width:150px}
    select:focus{border-color:#10b981;box-shadow:0 0 0 3px rgba(16,185,129,.15)}
    .table-wrap{background:#fff;border:1px solid #e2e8f0;border-radius:.75rem;overflow:hidden}
    .table-scroll{overflow-x:auto}
    table{width:100%;border-collapse:collapse;font-size:.875rem}
    thead{background:#f8fafc;border-bottom:1px solid #e2e8f0}
    th{text-align:left;padding:.75rem .9rem;font-weight:600;color:#475569;white-space:nowrap}
    tbody tr{border-bottom:1px solid #f1f5f9}tbody tr:hover{background:#f8fafc}
    tbody tr.row-overdue{background:#fef2f2}tbody tr.row-soon{background:#fff7ed}
    td{padding:.75rem .9rem;vertical-align:middle}
    .code{font-family:monospace;font-weight:500}
    .tipo-cell{display:flex;align-items:center;gap:.4rem}.tipo-cell i{color:#94a3b8;font-size:.75rem}
    .truncate{max-width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .badge{display:inline-block;font-size:.7rem;padding:.2rem .55rem;border-radius:9999px;font-weight:500}
    .badge-green{background:#d1fae5;color:#047857}.badge-amber{background:#fef3c7;color:#b45309}
    .badge-rose{background:#ffe4e6;color:#be123c}.badge-blue{background:#dbeafe;color:#1d4ed8}
    .badge-gray{background:#f1f5f9;color:#64748b}.badge-purple{background:#f3e8ff;color:#7e22ce}
    .overdue{color:#dc2626;font-weight:600}.soon{color:#ea580c;font-weight:600}
    .actions{display:flex;justify-content:center;gap:.25rem}
    .btn-icon{padding:.45rem;border:none;background:transparent;border-radius:.4rem;cursor:pointer;color:#94a3b8}
    .btn-icon.edit:hover{color:#059669;background:#ecfdf5}
    .btn-icon.delete:hover{color:#e11d48;background:#fff1f2}
    .btn-icon.history:hover{color:#7c3aed;background:#f5f3ff}
    .empty{display:none;padding:4rem 1rem;text-align:center;color:#94a3b8}.empty.show{display:block}
    .empty i{font-size:2.5rem;opacity:.5;margin-bottom:.75rem}
    .empty button{margin-top:.75rem;background:none;border:none;color:#059669;font-size:.875rem;font-weight:500;cursor:pointer;text-decoration:underline}
    .footer-note{font-size:.75rem;color:#94a3b8;text-align:center;margin-top:1rem}
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);z-index:50;display:none;align-items:center;justify-content:center;padding:1rem}
    .modal-overlay.show{display:flex}
    .modal{background:#fff;border-radius:1rem;width:100%;max-width:48rem;max-height:92vh;overflow-y:auto;box-shadow:0 25px 50px -12px rgba(0,0,0,.25)}
    .modal-lg{max-width:56rem}
    .modal-sm{max-width:420px}
    .modal-header{position:sticky;top:0;background:#fff;border-bottom:1px solid #f1f5f9;padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;z-index:10}
    .modal-header h2{font-size:1.125rem;font-weight:700}
    .modal-close{background:none;border:none;color:#94a3b8;font-size:1.25rem;cursor:pointer}
    .modal-body{padding:1.5rem}
    .form-grid{display:grid;grid-template-columns:1fr;gap:1rem}
    @media(min-width:640px){.form-grid{grid-template-columns:1fr 1fr}}
    .form-group.full{grid-column:1/-1}
    label{display:block;font-size:.75rem;font-weight:500;color:#475569;margin-bottom:.25rem}
    input[type=text],input[type=password],input[type=date],input[type=url],select,textarea{width:100%;padding:.6rem .75rem;border:1px solid #e2e8f0;border-radius:.5rem;font-size:.875rem;outline:none;font-family:inherit}
    input:focus,select:focus,textarea:focus{border-color:#10b981;box-shadow:0 0 0 3px rgba(16,185,129,.15)}
    textarea{resize:vertical;min-height:70px}
    .field-error{color:#ef4444;font-size:.75rem;margin-top:.3rem}
    input.error,select.error,textarea.error{border-color:#ef4444!important;box-shadow:0 0 0 3px rgba(239,68,68,.15)!important}
    .radio-group{display:flex;gap:1.5rem;margin-top:.3rem}
    .radio-option{display:flex;align-items:center;gap:.4rem;font-size:.875rem;cursor:pointer}
    .radio-option input{width:auto;margin:0}
    .conditional-fields{display:none;grid-column:1/-1;background:#f8fafc;border:1px solid #e2e8f0;border-radius:.5rem;padding:1rem;margin-top:.25rem}
    .conditional-fields.show{display:block}
    .conditional-fields .inner-grid{display:grid;grid-template-columns:1fr;gap:1rem}
    @media(min-width:640px){.conditional-fields .inner-grid{grid-template-columns:1fr 1fr}}
    .form-actions{display:flex;justify-content:flex-end;gap:.75rem;margin-top:1.5rem}
    .btn-cancel{padding:.6rem 1.25rem;border-radius:.5rem;border:1px solid #e2e8f0;background:#fff;color:#475569;font-size:.875rem;font-weight:500;cursor:pointer}
    .btn-cancel:hover{background:#f8fafc}
    .btn-save{padding:.6rem 1.25rem;border-radius:.5rem;border:none;background:#059669;color:#fff;font-size:.875rem;font-weight:500;cursor:pointer}
    .btn-save:hover{background:#10b981}
    .toast{position:fixed;bottom:1.5rem;right:1.5rem;background:#1e293b;color:#fff;padding:.75rem 1.25rem;border-radius:.75rem;font-size:.875rem;display:none;align-items:center;gap:.5rem;z-index:60;box-shadow:0 10px 15px -3px rgba(0,0,0,.1)}
    .toast.show{display:flex}.toast i{color:#34d399}
    .users-table{width:100%;border-collapse:collapse;font-size:.875rem;margin-top:1rem}
    .users-table th{text-align:left;padding:.6rem;background:#f8fafc;border-bottom:1px solid #e2e8f0}
    .users-table td{padding:.6rem;border-bottom:1px solid #f1f5f9}
    .reminder-box{background:#fffbeb;border:1px solid #fde68a;border-radius:.5rem;padding:.85rem 1rem;margin-bottom:1.25rem;font-size:.875rem;color:#92400e;display:flex;gap:.6rem;align-items:flex-start}
    .loading-overlay{position:fixed;inset:0;background:rgba(15,23,42,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:2000;color:#fff;font-size:1.05rem;gap:.75rem;text-align:center;padding:1.5rem}
    .loading-overlay.hidden{display:none}
    .loading-overlay .err{color:#fca5a5;font-size:.9rem;max-width:520px;margin-top:.5rem}
    .device-info{background:#f8fafc;border:1px solid #e2e8f0;border-radius:.5rem;padding:.85rem 1rem;margin-bottom:1.25rem;font-size:.875rem}
    .device-info strong{color:#0f172a}
    .history-table{width:100%;border-collapse:collapse;font-size:.85rem;margin-top:.75rem}
    .history-table th{text-align:left;padding:.55rem .6rem;background:#f8fafc;border-bottom:1px solid #e2e8f0;font-size:.75rem;color:#475569}
    .history-table td{padding:.55rem .6rem;border-bottom:1px solid #f1f5f9;vertical-align:top}
    .history-empty{text-align:center;color:#94a3b8;padding:1.5rem;font-size:.875rem}
    .section-title{font-size:.95rem;font-weight:600;margin:1.25rem 0 .75rem;color:#0f172a;display:flex;align-items:center;gap:.5rem}
    .checkbox-row{display:flex;align-items:center;gap:.5rem;font-size:.875rem;margin-top:.5rem}
    .checkbox-row input{width:auto}
  </style>
</head>
<body>

<div id="loadingOverlay" class="loading-overlay">
  <div><i class="fas fa-spinner fa-spin"></i> Connessione a Firebase...</div>
  <div id="loadingError" class="err"></div>
</div>

<div id="loginScreen" class="login-screen hidden">
  <div class="login-box">
    <div class="login-logo">
      <i class="fas fa-flask"></i>
      <h1>Gestione Strumentazione</h1>
      <p>Laboratorio • Sincronizzato in tempo reale</p>
    </div>
    <div id="loginError" class="login-error"></div>
    <div class="form-group">
      <label>Username</label>
      <input type="text" id="loginUsername" placeholder="Inserisci username" autocomplete="username">
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" id="loginPassword" placeholder="Inserisci password" autocomplete="current-password">
    </div>
    <button class="btn-login" onclick="doLogin()">Accedi</button>
    <p class="login-hint">Default: admin / admin123</p>
  </div>
</div>

<div id="app" class="app">
  <header class="header">
    <div class="header-inner">
      <div class="logo">
        <div class="logo-icon"><i class="fas fa-flask"></i></div>
        <div>
          <h1>Gestione Strumentazione <span class="sync-badge"><i class="fas fa-cloud"></i> Live</span></h1>
          <p>Cappe • Armadi • Armadietti • Sicurezza • HALO</p>
        </div>
      </div>
      <div class="header-actions">
        <div class="user-badge">
          <i class="fas fa-user"></i>
          <span id="currentUserName">—</span>
          <span class="role" id="currentUserRole"></span>
        </div>
        <button class="btn btn-secondary" id="btnUsers" onclick="openUsersModal()" style="display:none"><i class="fas fa-users"></i> Utenti</button>
        <button class="btn btn-email" id="btnEmail" onclick="sendExpiryEmail(true)" style="display:none"><i class="fas fa-envelope"></i> Invia avviso</button>
        <button class="btn btn-secondary" onclick="exportData()"><i class="fas fa-download"></i> JSON</button>
        <button class="btn btn-excel" onclick="exportExcel()"><i class="fas fa-file-excel"></i> Excel</button>
        <label class="btn btn-secondary" id="btnImport" style="cursor:pointer;display:none">
          <i class="fas fa-upload"></i> Importa JSON
          <input type="file" accept=".json" style="display:none" onchange="importData(event)">
        </label>
        <label class="btn btn-excel" id="btnImportExcel" style="cursor:pointer;display:none">
          <i class="fas fa-file-excel"></i> Importa Excel
          <input type="file" accept=".xlsx,.xls" style="display:none" onchange="importExcel(event)">
        </label>
        <button class="btn btn-primary" id="btnNuovo" onclick="openModal()" style="display:none"><i class="fas fa-plus"></i> Nuovo</button>
        <button class="btn btn-danger" onclick="doLogout()"><i class="fas fa-sign-out-alt"></i> Esci</button>
      </div>
    </div>
  </header>

  <div id="expiryAlert" class="expiry-alert">
    <div class="expiry-alert-inner">
      <i class="fas fa-exclamation-triangle"></i>
      <div id="expiryAlertText"></div>
      <button class="btn-sm" onclick="filterExpiring()">Mostra solo questi</button>
    </div>
  </div>

  <main class="main">
    <div class="stats" id="statsContainer"></div>
    <div class="filters">
      <div class="filters-inner">
        <div class="search-wrap">
          <i class="fas fa-search"></i>
          <input type="text" id="searchInput" placeholder="Cerca..." oninput="renderTable()">
        </div>
        <select id="filterTipo" onchange="renderTable()">
          <option value="">Tutti i tipi</option>
          <option value="Cappa chimica">Cappe chimiche</option>
          <option value="Armadietto aspirato">Armadietti aspirati</option>
          <option value="Armadietto non aspirato">Armadietti non aspirati</option>
          <option value="Armadio di sicurezza">Armadi di sicurezza</option>
          <option value="Cappa a filtrazione">Cappe a filtrazione</option>
          <option value="HALO">HALO</option>
        </select>
        <select id="filterStato" onchange="renderTable()">
          <option value="">Tutti gli stati</option>
          <option value="Attivo">Attivo</option>
          <option value="In manutenzione">In manutenzione</option>
          <option value="Fuori servizio">Fuori servizio</option>
        </select>
        <select id="filterScadenza" onchange="renderTable()">
          <option value="">Tutte le scadenze</option>
          <option value="scaduti">Solo scaduti</option>
          <option value="in_scadenza">In scadenza (30 gg)</option>
          <option value="ok">In regola</option>
        </select>
      </div>
    </div>

    <div class="table-wrap">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Serial Number</th>
              <th>ID Dispositivo</th>
              <th>Tipo</th>
              <th>Modello / Marca</th>
              <th>Ubicazione</th>
              <th>Sistema filtrante</th>
              <th>Prefiltro</th>
              <th>Stato</th>
              <th>Ultima man.</th>
              <th>Prossima man.</th>
              <th>Responsabile</th>
              <th id="thAzioni">Azioni</th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
      <div id="emptyState" class="empty">
        <i class="fas fa-inbox"></i>
        <p>Nessuna strumentazione trovata</p>
        <button id="btnEmptyAdd" onclick="openModal()" style="display:none">Aggiungi la prima</button>
      </div>
    </div>
    <p class="footer-note">Dati sincronizzati in tempo reale con Firebase. Storico manutenzioni disponibile su ogni DPC.</p>
  </main>
</div>

<!-- Modal dispositivo -->
<div id="modal" class="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle">Nuova strumentazione</h2>
      <button class="modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="reminder-box">
        <i class="fas fa-info-circle" style="margin-top:2px;flex-shrink:0"></i>
        <div><strong>Promemoria:</strong> se manca un dato obbligatorio, inserisci <strong>N.A.</strong></div>
      </div>
      <input type="hidden" id="editId">
      <div class="form-grid">
        <div class="form-group"><label>Serial Number *</label><input type="text" id="serialNumber"></div>
        <div class="form-group"><label>ID Dispositivo *</label><input type="text" id="idDispositivo"></div>
        <div class="form-group">
          <label>Tipo *</label>
          <select id="tipo">
            <option value="">Seleziona...</option>
            <option value="Cappa chimica">Cappa chimica</option>
            <option value="Armadietto aspirato">Armadietto aspirato</option>
            <option value="Armadietto non aspirato">Armadietto non aspirato</option>
            <option value="Armadio di sicurezza">Armadio di sicurezza</option>
            <option value="Cappa a filtrazione">Cappa a filtrazione</option>
            <option value="HALO">HALO</option>
          </select>
        </div>
        <div class="form-group"><label>Marca</label><input type="text" id="marca"></div>
        <div class="form-group"><label>Modello</la